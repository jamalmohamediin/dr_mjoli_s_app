rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /development_state/{document=**} {
      allow read, write: if true;
    }

    match /patients/{document=**} {
      allow read, write: if true;
    }

    match /patient_records/{document=**} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
